---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
  ogType?: "website" | "article";
  publishedTime?: string;
}

const {
  title = "Daniel Jeun",
  description = "Daniel Jeun Valenzuela. AI engineer, NJIT Data Science '26. Newark, NJ.",
  ogType = "website",
  publishedTime,
} = Astro.props;

const fullTitle = title === "Daniel Jeun" ? title : `${title} — Daniel Jeun`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL("/og-default.png", Astro.site).toString();

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Daniel Jeun Valenzuela",
  url: Astro.site?.toString() ?? "https://danijeun.com",
  jobTitle: "AI engineer",
  email: "mailto:danijeun@gmail.com",
  alumniOf: {
    "@type": "CollegeOrUniversity",
    name: "New Jersey Institute of Technology",
  },
  sameAs: [
    "https://github.com/danijeun",
    "https://www.linkedin.com/in/danijeun",
    "https://devpost.com/danijeun",
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Daniel Jeun Valenzuela" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#f7f3ec" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,300..800;1,6..72,300..800&family=Libre+Franklin:ital,wght@0,300..900;1,300..900&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
    />
    <ClientRouter />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Daniel Jeun" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {ogType === "article" && <meta property="article:author" content="Daniel Jeun Valenzuela" />}
    <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />
    <title>{fullTitle}</title>
  </head>
  <body class="bg-[var(--color-cream)] text-[var(--color-ink)]">
    <a
      href="#main"
      class="absolute left-2 top-2 -translate-y-20 focus-visible:translate-y-0 bg-[var(--color-ink)] text-[var(--color-cream)] px-3 py-2 text-sm font-[var(--font-sans)] z-50 transition-transform"
      style="border-bottom: 0;"
    >
      Skip to main content
    </a>
    <main id="main">
      <slot />
    </main>
  </body>
</html>
