---
import Base from "./Base.astro";
import Masthead from "../components/ui/Masthead.astro";
import Kicker from "../components/ui/Kicker.astro";
import Headline from "../components/ui/Headline.astro";
import Dek from "../components/ui/Dek.astro";
import Byline from "../components/ui/Byline.astro";
import SectionRule from "../components/ui/SectionRule.astro";
import Figure from "../components/ui/Figure.astro";
import Sidebar from "../components/ui/Sidebar.astro";
import FactBox from "../components/ui/FactBox.astro";
import Tag from "../components/ui/Tag.astro";

interface Props {
  title: string;
  kicker: string;
  dek: string;
  year: number;
  role: string;
  stack: string[];
  links?: {
    github?: string;
    live?: string;
    devpost?: string;
    paper?: string;
    demo?: string;
    npm?: string;
  };
  hero?: string;
  heroCaption?: string;
  heroCredit?: string;
  whatBroke?: string;
  description?: string;
}

const {
  title,
  kicker,
  dek,
  year,
  role,
  stack,
  links = {},
  hero,
  heroCaption,
  heroCredit,
  whatBroke,
  description,
} = Astro.props;

const linkPairs: [string, string][] = [
  links.github ? ["GitHub", links.github] : null,
  links.live ? ["Live", links.live] : null,
  links.devpost ? ["Devpost", links.devpost] : null,
  links.paper ? ["Paper", links.paper] : null,
  links.demo ? ["Demo", links.demo] : null,
  links.npm ? ["npm", links.npm] : null,
].filter(Boolean) as [string, string][];

const linksHtml =
  linkPairs.length > 0
    ? linkPairs
        .map(([label, url]) => `<a href="${url}">${label}</a>`)
        .join('<span aria-hidden="true" style="color:var(--color-rule);margin:0 .5rem"> · </span>')
    : "—";

const factRows = [
  { label: "Year", value: String(year) },
  { label: "Role", value: role },
  { label: "Stack", value: stack.join(", ") },
  { label: "Links", value: linksHtml },
];
---

<Base title={title} description={description ?? dek}>
  <Masthead />

  <article class="mx-auto max-w-3xl px-6 pt-10 pb-24">
    <header>
      <Kicker tone="red">{kicker}</Kicker>
      <Headline size="display" class="mt-3">{title}</Headline>
      <Dek class="mt-5">{dek}</Dek>
      <Byline live location="Newark" class="mt-6" />
      <SectionRule class="mt-8" />
    </header>

    {
      hero && (
        <Figure src={hero} alt={`${title} hero image`} caption={heroCaption} credit={heroCredit} />
      )
    }

    <div class="prose-article">
      <slot />
    </div>

    {
      whatBroke && (
        <Sidebar title="What broke">
          <p set:html={whatBroke} />
        </Sidebar>
      )
    }

    <FactBox title="The facts" rows={factRows} />

    <div class="mt-6 flex flex-wrap gap-2">
      {stack.map((s) => <Tag>{s}</Tag>)}
    </div>

    <SectionRule class="mt-12" tone="ink" />
    <p class="mt-6 font-[var(--font-sans)] text-[var(--text-meta)] text-[var(--color-meta)] italic">
      <a href="/projects">&larr; Back to all projects</a>
    </p>
  </article>
</Base>

<style is:global>
  .prose-article > p {
    font-family: var(--font-serif);
    font-size: var(--text-body);
    line-height: 1.65;
    margin-top: 1.1rem;
  }
  .prose-article > p:first-of-type::first-letter {
    font-family: var(--font-serif);
    font-weight: 500;
    float: left;
    font-size: 4.4em;
    line-height: 0.9;
    padding: 0.05em 0.08em 0 0;
    margin-top: 0.05em;
    color: var(--color-ink);
    font-variation-settings: "opsz" 72;
  }
  .prose-article h2 {
    font-family: var(--font-serif);
    font-size: var(--text-h3);
    font-weight: 500;
    margin-top: 2.5rem;
    margin-bottom: 0.5rem;
    font-variation-settings: "opsz" 72;
  }
  .prose-article h3 {
    font-family: var(--font-sans);
    font-size: var(--text-meta);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 600;
    margin-top: 1.75rem;
    margin-bottom: 0.25rem;
    color: var(--color-meta);
  }
  .prose-article a {
    color: inherit;
    border-bottom: 1px solid var(--color-rule);
  }
  .prose-article a:hover {
    color: var(--color-red);
    border-bottom-color: var(--color-red);
  }
  .prose-article ul {
    list-style: none;
    padding: 0;
    margin: 1rem 0;
  }
  .prose-article ul li {
    font-family: var(--font-serif);
    font-size: var(--text-body);
    line-height: 1.55;
    padding-left: 1.25rem;
    position: relative;
    margin-top: 0.5rem;
  }
  .prose-article ul li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--color-meta);
  }
</style>
