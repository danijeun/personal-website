---
import Kicker from "./Kicker.astro";

interface Props {
  href: string;
  kicker: string;
  title: string;
  dek?: string;
  year?: number;
  size?: "lead" | "standard" | "compact";
  class?: string;
}
const {
  href,
  kicker,
  title,
  dek,
  year,
  size = "standard",
  class: className = "",
} = Astro.props;
const titleSize = {
  lead: "text-3xl md:text-5xl",
  standard: "text-2xl md:text-3xl",
  compact: "text-xl md:text-2xl",
}[size];
---

<a
  href={href}
  class={`group block py-5 border-b border-[var(--color-rule)] ${className}`}
  style="border-bottom-width: 1px;"
>
  <Kicker tone="red">{kicker}</Kicker>
  <h3
    class={`mt-2 font-[var(--font-serif)] ${titleSize} leading-[1.05] tracking-tight text-[var(--color-ink)] group-hover:text-[var(--color-red)] transition-colors`}
    style="font-variation-settings: 'opsz' 144;"
  >
    {title}
  </h3>
  {
    dek && (
      <p class="mt-2 font-[var(--font-serif)] italic text-[var(--color-meta)] leading-snug">
        {dek}
      </p>
    )
  }
  {
    year && (
      <p class="mt-3 font-[var(--font-sans)] text-[var(--text-meta)] text-[var(--color-meta)] uppercase tracking-[0.12em]">
        {year}
      </p>
    )
  }
</a>
