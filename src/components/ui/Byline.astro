---
interface Props {
  author?: string;
  dateline?: string;
  live?: boolean;
  location?: string;
  class?: string;
}
const {
  author = "Daniel Jeun",
  dateline,
  live = false,
  location = "Newark",
  class: className = "",
} = Astro.props;

// Build time fallback. Month + year only, because anything more specific
// (weekday, day) goes stale the moment the CDN serves a cached build.
// The client script below replaces this with the visitor's real current
// date as soon as JS runs.
const fallback = live
  ? `${location}, ${new Date().toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      timeZone: "America/New_York",
    })}`
  : null;
---

<p
  class={`font-[var(--font-sans)] text-[var(--text-meta)] text-[var(--color-meta)] flex flex-wrap items-baseline gap-x-3 ${className}`}
>
  <span class="text-[var(--color-ink)]">By {author}</span>
  {
    (dateline || live) && (
      <>
        <span aria-hidden="true" class="text-[var(--color-rule)]">
          |
        </span>
        {live ? (
          <time class="italic" data-live-dateline data-location={location}>
            {fallback}
          </time>
        ) : (
          <span class="italic">{dateline}</span>
        )}
      </>
    )
  }
</p>

{
  live && (
    <script is:inline>
      (function () {
        var nodes = document.querySelectorAll("[data-live-dateline]");
        if (!nodes.length) return;
        var now = new Date();
        var today = now.toLocaleDateString(undefined, {
          weekday: "long",
          year: "numeric",
          month: "long",
          day: "numeric",
        });
        var iso = now.getFullYear() + "-" +
          String(now.getMonth() + 1).padStart(2, "0") + "-" +
          String(now.getDate()).padStart(2, "0");
        nodes.forEach(function (el) {
          var loc = el.getAttribute("data-location") || "Newark";
          el.textContent = loc + ", " + today;
          el.setAttribute("datetime", iso);
        });
      })();
    </script>
  )
}
