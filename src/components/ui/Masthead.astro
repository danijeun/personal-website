---
import SectionRule from "./SectionRule.astro";

interface NavItem {
  href: string;
  label: string;
}
const nav: NavItem[] = [
  { href: "/", label: "Front" },
  { href: "/projects", label: "Projects" },
  { href: "/about", label: "About" },
  { href: "/ask", label: "Ask" },
  { href: "/contact", label: "Contact" },
];
const path = Astro.url.pathname;
---

<header class="pt-8 pb-2">
  <div class="mx-auto max-w-6xl px-6 flex items-baseline justify-between gap-6">
    <div class="flex items-baseline gap-4">
      <a
        href="/"
        class="font-[var(--font-serif)] text-3xl md:text-4xl tracking-tight text-[var(--color-ink)]"
        style="border-bottom: 0; font-variation-settings: 'opsz' 72;"
      >
        Daniel Jeun
      </a>
      <span
        class="hidden sm:inline font-[var(--font-sans)] italic text-[var(--text-meta)] text-[var(--color-meta)]"
      >
        Newark, NJ &middot; Vol I
      </span>
    </div>
    <nav aria-label="Main">
      <ul class="flex flex-wrap items-baseline gap-x-5 gap-y-1">
        {
          nav.map((item) => {
            const isActive = path === item.href || (item.href !== "/" && path.startsWith(item.href));
            return (
              <li>
                <a
                  href={item.href}
                  class={`font-[var(--font-sans)] uppercase tracking-[0.14em] text-[0.75rem] font-medium ${
                    isActive ? "text-[var(--color-red)]" : "text-[var(--color-ink)]"
                  }`}
                  style="border-bottom: 0;"
                >
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
  <div class="mt-3 mx-auto max-w-6xl px-6">
    <SectionRule tone="red" class="border-t-2" />
  </div>
</header>
