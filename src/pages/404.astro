---
import Base from "../layouts/Base.astro";
---

<Base title="404">
  <section class="mx-auto max-w-[var(--container-article)] px-6 pt-32 pb-32 text-center">
    <p
      class="font-[var(--font-sans)] text-[var(--text-kicker)] uppercase tracking-[0.18em] text-[var(--color-red)]"
    >
      Error
    </p>
    <h1 class="mt-4 font-[var(--font-serif)] text-7xl md:text-9xl tracking-tight">404</h1>
    <p class="mt-4 font-[var(--font-serif)] italic text-[var(--text-dek)]">Spiked.</p>
    <p class="mt-3 font-[var(--font-serif)] text-[var(--color-meta)]">
      Whatever you were looking for didn't make it past the desk.
    </p>
    <p class="mt-10 font-[var(--font-sans)] text-[var(--text-meta)]">
      <a href="/">Return to the front page &rarr;</a>
    </p>
  </section>
</Base>
