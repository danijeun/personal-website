---
import Base from "../layouts/Base.astro";
import Masthead from "../components/ui/Masthead.astro";
import Kicker from "../components/ui/Kicker.astro";
import Headline from "../components/ui/Headline.astro";
import Dek from "../components/ui/Dek.astro";
import Byline from "../components/ui/Byline.astro";
import SectionRule from "../components/ui/SectionRule.astro";
import FactBox from "../components/ui/FactBox.astro";

const channels = [
  { label: "Email", value: '<a href="mailto:danijeun@gmail.com">danijeun@gmail.com</a>' },
  { label: "GitHub", value: '<a href="https://github.com/danijeun">github.com/danijeun</a>' },
  {
    label: "LinkedIn",
    value: '<a href="https://www.linkedin.com/in/danijeun">linkedin.com/in/danijeun</a>',
  },
  { label: "Devpost", value: '<a href="https://devpost.com/danijeun">devpost.com/danijeun</a>' },
];
---

<Base title="Contact" description="How to reach Daniel Jeun. Email, GitHub, LinkedIn, Devpost.">
  <Masthead />

  <article class="mx-auto max-w-3xl px-6 pt-10 pb-24">
    <Kicker tone="red">The desk</Kicker>
    <Headline size="display" class="mt-3">Get in touch.</Headline>
    <Dek class="mt-5">
      Email is fastest. The form below works too. I read everything, even the ones from recruiters
      I've never met.
    </Dek>
    <Byline live location="Newark" class="mt-6" />
    <SectionRule class="mt-8" />

    <FactBox title="Channels" rows={channels} />

    <section class="mt-12">
      <Kicker>Or write in</Kicker>
      <form
        method="POST"
        action="/api/contact"
        class="mt-4 grid grid-cols-1 gap-4"
      >
        <label class="block">
          <span
            class="font-[var(--font-sans)] uppercase tracking-[0.12em] text-[0.75rem] text-[var(--color-meta)]"
          >
            Your name
          </span>
          <input
            type="text"
            name="name"
            required
            class="mt-1 w-full bg-transparent border-0 border-b border-[var(--color-rule)] focus:border-[var(--color-ink)] focus:outline-none py-2 font-[var(--font-serif)] text-[var(--text-body)]"
          />
        </label>
        <label class="block">
          <span
            class="font-[var(--font-sans)] uppercase tracking-[0.12em] text-[0.75rem] text-[var(--color-meta)]"
          >
            Email
          </span>
          <input
            type="email"
            name="email"
            required
            class="mt-1 w-full bg-transparent border-0 border-b border-[var(--color-rule)] focus:border-[var(--color-ink)] focus:outline-none py-2 font-[var(--font-serif)] text-[var(--text-body)]"
          />
        </label>
        <label class="block">
          <span
            class="font-[var(--font-sans)] uppercase tracking-[0.12em] text-[0.75rem] text-[var(--color-meta)]"
          >
            Message
          </span>
          <textarea
            name="message"
            rows="6"
            required
            class="mt-1 w-full bg-transparent border border-[var(--color-rule)] focus:border-[var(--color-ink)] focus:outline-none p-3 font-[var(--font-serif)] text-[var(--text-body)]"
          ></textarea>
        </label>
        <div>
          <button
            type="submit"
            class="font-[var(--font-sans)] uppercase tracking-[0.18em] text-[0.75rem] px-5 py-3 bg-[var(--color-ink)] text-[var(--color-cream)] hover:bg-[var(--color-red)] transition-colors"
          >
            Send to the desk
          </button>
        </div>
        <p
          class="font-[var(--font-sans)] text-[var(--text-meta)] italic text-[var(--color-meta)]"
        >
          The form will start working in sprint 3 once the contact endpoint is wired. Until then,
          email goes through.
        </p>
      </form>
    </section>
  </article>
</Base>
