---
import Base from "../../layouts/Base.astro";
import Masthead from "../../components/ui/Masthead.astro";
import Kicker from "../../components/ui/Kicker.astro";
import Headline from "../../components/ui/Headline.astro";
import Dek from "../../components/ui/Dek.astro";
import Byline from "../../components/ui/Byline.astro";
import SectionRule from "../../components/ui/SectionRule.astro";
import Tag from "../../components/ui/Tag.astro";
import DropCap from "../../components/ui/DropCap.astro";
import Figure from "../../components/ui/Figure.astro";
import PullQuote from "../../components/ui/PullQuote.astro";
import Sidebar from "../../components/ui/Sidebar.astro";
import FactBox from "../../components/ui/FactBox.astro";
import ArticleCard from "../../components/ui/ArticleCard.astro";

const factRows = [
  { label: "Stack", value: "React, Flask, Snowflake, Gemini 2.5" },
  { label: "Role", value: "Solo" },
  { label: "Year", value: "2025" },
  { label: "Athletics", value: "NJIT Men's Fencing, NCAA Division I, &eacute;p&eacute;e, '26" },
  {
    label: "Links",
    value: '<a href="https://github.com/danijeun/foresee-app">github</a>',
  },
];
---

<Base title="Components" description="Editorial component library demo. Not for visitors.">
  <Masthead />

  <article class="mx-auto max-w-3xl px-6 py-12">
    <Kicker tone="red">Internal &middot; Style guide</Kicker>
    <Headline size="display" class="mt-3">The set is being struck.</Headline>
    <Dek class="mt-5">
      Every editorial primitive that ships on this site lives on this page first. If it cannot be
      proofed here, it does not go to print.
    </Dek>
    <Byline dateline="Newark, April 2026" class="mt-6" />

    <SectionRule class="mt-10" />

    <section class="mt-10">
      <Kicker>1. Headlines</Kicker>
      <div class="mt-4 space-y-6">
        <Headline size="display">A display headline</Headline>
        <Headline size="h1">An H1 headline</Headline>
        <Headline size="h2">An H2 headline</Headline>
        <Headline size="h3">An H3 headline</Headline>
      </div>
    </section>

    <SectionRule class="mt-10" />

    <section class="mt-10">
      <Kicker>2. Byline and kicker variants</Kicker>
      <div class="mt-4 space-y-3">
        <Kicker tone="red">Projects</Kicker>
        <Kicker tone="ink">Projects</Kicker>
        <Kicker tone="meta">Projects</Kicker>
        <Byline />
        <Byline dateline="Newark, March 2026" />
        <Byline author="The desk" dateline="Filed 11:47 PM" />
      </div>
    </section>

    <SectionRule class="mt-10" />

    <section class="mt-10">
      <Kicker>3. Body type with drop cap</Kicker>
      <DropCap class="mt-4">
        <p class="font-[var(--font-serif)]">
          The first paragraph of every project article gets a three line initial cap. Daniel reads
          the page out loud before it ships. If a sentence sounds like a LinkedIn post, it gets
          cut. If it sounds like a friend telling a story over coffee, it stays.
        </p>
        <p class="mt-4 font-[var(--font-serif)]">
          The second paragraph carries on at body weight, with a longer measure than a marketing
          page would use. Editorial typography rewards patience.
        </p>
      </DropCap>
    </section>

    <SectionRule class="mt-10" />

    <section class="mt-10">
      <Kicker>4. Pull quote</Kicker>
      <PullQuote attribution="Daniel, on building Brisca in 48 hours">
        Couldn't find a Spanish deck anywhere, so I drew one.
      </PullQuote>
    </section>

    <SectionRule class="mt-10" />

    <section class="mt-10">
      <Kicker>5. Sidebar</Kicker>
      <Sidebar title="What broke">
        <p>
          Snowflake's connection pool died under parallel load on free tier. Hit the limit at three
          concurrent EDA jobs. Fix was a queue, not a bigger plan.
        </p>
        <p>
          The Gemini target ranking was great until someone uploaded a CSV with one column. The
          model confidently picked it as both target and feature.
        </p>
      </Sidebar>
    </section>

    <SectionRule class="mt-10" />

    <section class="mt-10">
      <Kicker>6. Fact box</Kicker>
      <FactBox title="Foresee &middot; The facts" rows={factRows} />
    </section>

    <SectionRule class="mt-10" />

    <section class="mt-10">
      <Kicker>7. Tags</Kicker>
      <div class="mt-4 flex flex-wrap gap-2">
        <Tag>Python</Tag>
        <Tag>React</Tag>
        <Tag active>AI</Tag>
        <Tag href="/projects?tag=ml">Machine learning</Tag>
        <Tag>Hackathon</Tag>
      </div>
    </section>

    <SectionRule class="mt-10" />

    <section class="mt-10">
      <Kicker>8. Figure</Kicker>
      <Figure
        src="https://placehold.co/1200x675/efe9dc/111111/png?text=Hero+image+placeholder"
        alt="Placeholder hero image set on a cream background."
        caption="A hero image always carries an italic caption underneath."
        credit="Daniel Jeun"
      />
    </section>

    <SectionRule class="mt-10" />

    <section class="mt-10">
      <Kicker>9. Article cards</Kicker>
      <div class="mt-4">
        <ArticleCard
          href="/projects/foresee"
          kicker="Machine learning"
          title="Foresee: an AutoML platform that turns CSV files into ML reports in 60 seconds."
          dek="A 5 step pipeline from upload to a downloadable PDF, ranked by Gemini and trained on three models in parallel."
          year={2025}
          size="lead"
        />
        <ArticleCard
          href="/projects/fanar-mcp"
          kicker="LLM infrastructure"
          title="Fanar MCP: function calling for an LLM that doesn't natively support it."
          dek="A prompt engineering layer that bridges Fanar to the Model Context Protocol, plus an npm published MCP server."
          year={2025}
        />
        <ArticleCard
          href="/projects/lets-play-brisca"
          kicker="Hackathon"
          title="Let's Play Brisca."
          dek="48 hours, a Spanish deck I had to draw myself, and an AI that conserves trump cards like my friends."
          year={2025}
          size="compact"
        />
      </div>
    </section>

    <SectionRule class="mt-12" tone="ink" />
    <p class="mt-6 font-[var(--font-sans)] text-[var(--text-meta)] text-[var(--color-meta)] italic">
      End of style guide. <a href="/">Return to the front page &rarr;</a>
    </p>
  </article>
</Base>
