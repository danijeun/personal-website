---
import Base from "../layouts/Base.astro";
---

<Base>
  <section class="mx-auto max-w-[var(--container-article)] px-6 pt-24 pb-32">
    <p
      class="font-[var(--font-sans)] text-[var(--text-kicker)] uppercase tracking-[0.18em] text-[var(--color-red)]"
    >
      Vol I &mdash; In progress
    </p>
    <h1 class="mt-6 font-[var(--font-serif)] text-5xl md:text-7xl leading-[0.95] tracking-tight">
      Daniel Jeun
    </h1>
    <p class="mt-6 font-[var(--font-serif)] italic text-[var(--text-dek)] text-[var(--color-meta)]">
      A site is being set in type. Come back soon.
    </p>
    <hr class="mt-10 border-0 border-t border-[var(--color-rule)]" />
    <p
      class="mt-6 font-[var(--font-sans)] text-[var(--text-meta)] text-[var(--color-meta)]"
    >
      Newark, NJ. Built with Astro. Drafts running daily.
    </p>
  </section>
</Base>
